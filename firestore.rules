rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function myUserDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function myRole() {
      return exists(myUserDocPath()) ? get(myUserDocPath()).data.role : null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        myRole() in ['admin', 'manager', 'super_admin', 'system_admin', 'operation_admin', 'branch_manager']
      );
    }

    function isStaff() {
      return isSignedIn() &&
        myRole() != 'customer' &&
        exists(myUserDocPath()) &&
        get(myUserDocPath()).data.status == 'active';
    }

    function canReadOwnInvitation() {
      return isSignedIn() &&
        resource.data.status == 'invited' &&
        resource.data.email == request.auth.token.email;
    }

    function isOwnProfilePayload(userId) {
      return isOwner(userId) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email;
    }

    function ownerProfileUpdateOnly(userId) {
      return isOwner(userId) &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'displayName',
          'photoURL',
          'phoneNumber',
          'providerIds',
          'updatedAt'
        ]);
    }

    // Public catalog
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /catalog_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Private user profile
    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff() || isAdmin() || canReadOwnInvitation();
      // NOTE: This allows client-side invite activation on first login.
      // For stricter security, move invitation acceptance to trusted backend code.
      allow create: if isAdmin() || isOwnProfilePayload(userId);
      allow update: if isAdmin() || ownerProfileUpdateOnly(userId);
      allow delete: if isAdmin();
    }

    // User orders
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isStaff() ||
        isAdmin()
      );
      allow update: if isStaff() || isAdmin();
      allow delete: if isAdmin();
    }

    // Promotions management
    match /coupons/{couponId} {
      allow read: if isStaff() || isAdmin();
      allow write: if isAdmin();
    }

    match /giftCards/{giftCardId} {
      allow read: if isStaff() || isAdmin();
      allow write: if isAdmin();
    }

    match /promotions/{promotionId} {
      allow read: if isStaff() || isAdmin();
      allow write: if isAdmin();
    }

    match /role_definitions/{roleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /team_chats/{chatId} {
      allow read, write: if isStaff() || isAdmin();
    }

    match /team_chat_meta/{docId} {
      allow read, write: if isStaff() || isAdmin();
    }

    match /sticky_notes/{noteId} {
      allow read, write: if isStaff() || isAdmin();
    }

    match /sales/{saleId} {
      allow read, write: if isStaff() || isAdmin();
    }

    // Default: deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
